# Optional: raises GitHub API rate limit from 60/hr to 5000/hr.
# Read-only scope is sufficient for the analysis pipeline.
GITHUB_TOKEN=

# Required only for --llm mode (real ADK + Gemini multi-agent orchestration).
# Heuristic mode (default) needs no key at all.
GOOGLE_API_KEY=

# Required only if you want PR Janitor to actually post approved comments
# to GitHub. Must have write scope (repo:status / public_repo). Without
# this, approved actions stay in "approved" state but are never posted —
# this is intentional, see src/tools/github_client.py post_comment_if_approved().
GITHUB_WRITE_TOKEN=
